events {}

http {

  # Redirect HTTP → HTTPS
  server {
    listen 80;
    return 301 https://$host$request_uri;
  }

  # Grafana
  server {
    listen 443 ssl;

    ssl_certificate /etc/nginx/certs/172.17.2.21.crt;
    ssl_certificate_key /etc/nginx/certs/172.17.2.21.key;

    location / {
        proxy_pass http://grafana:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}
    # Prometheus
    server {
    listen 9091 ssl;

    ssl_certificate /etc/nginx/certs/172.17.2.21.crt;
    ssl_certificate_key /etc/nginx/certs/172.17.2.21.key;

    location / {
        proxy_pass http://prometheus:9090;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}

  # MinIO
  server {
    listen 9443 ssl;

    ssl_certificate /etc/nginx/certs/172.17.2.21.crt;
    ssl_certificate_key /etc/nginx/certs/172.17.2.21.key;

    location / {
      proxy_pass http://minio:9001;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
    }
  }
}
